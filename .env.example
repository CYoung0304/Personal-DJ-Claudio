# Claudio - Environment Variables
# 复制此文件为 .env 后填入你自己的 key
#
# cp .env.example .env

# ===== AI Provider =====
# 二选一：claude（默认）或 deepseek
AI_PROVIDER=deepseek

# --- 选项 A：DeepSeek（便宜，国内直连，推荐） ---
# 在 https://platform.deepseek.com/ 注册获取 key（约 ¥1 / 百万 tokens）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MODEL=deepseek-reasoner   # 推理型，慢但更严谨

# --- 选项 B：Claude（官方 Anthropic API） ---
# 在 https://console.anthropic.com/ 获取 key
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=                # 仅当走自建代理时填写，否则留空

# ===== TTS（DJ 语音）Provider =====
# 二选一：edge（免费，默认）或 openai-compatible（自定义 OpenAI 风格 TTS API）
TTS_PROVIDER=edge

# --- 选项 A：微软 Edge TTS（免费，无需 key） ---
# 完整音色列表：https://learn.microsoft.com/azure/ai-services/speech-service/language-support?tabs=tts
TTS_VOICE_EDGE=zh-CN-XiaoxiaoNeural

# --- 选项 B：OpenAI 兼容的 TTS（如自建代理 / 第三方付费 TTS） ---
# 走 POST {TTS_BASE_URL}/v1/audio/speech，用 TTS_API_KEY 鉴权
# TTS_PROVIDER=openai
# TTS_BASE_URL=https://your-tts-endpoint.example.com
# TTS_API_KEY=
# TTS_MODEL=tts-1
# TTS_VOICE=alloy

# ===== 网易云音乐 =====
# 可选：登录后的 cookie（从浏览器 DevTools 复制 MUSIC_U=... 整段）
# 不填也能跑，但 VIP 歌曲 / 高品质音源会拿不到
NCM_COOKIE=

# ===== Server =====
PORT=8080
